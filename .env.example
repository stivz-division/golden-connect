# === Docker ===
COMPOSE_PROJECT_NAME=golden-connect

APP_NAME="Golden Connect"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# === Database (MySQL) ===
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=golden_connect
DB_USERNAME=app
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme-root

# === Session ===
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# === Services ===
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# === Redis ===
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# === Mail ===
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@golden-connect.com"
MAIL_FROM_NAME="${APP_NAME}"

# === Octane ===
OCTANE_SERVER=swoole

# === Reverb (WebSocket) ===
REVERB_APP_ID=golden-connect
REVERB_APP_KEY=golden-connect-key
REVERB_APP_SECRET=golden-connect-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# === Vite ===
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# === Ports (dev) ===
APP_PORT=8000
HTTP_PORT=80
DB_PORT=3306
REDIS_PORT=6379
REVERB_PORT=8080

# === Telegram Gateway ===
TELEGRAM_GATEWAY_TOKEN=

# === Google reCAPTCHA v3 ===
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_THRESHOLD=0.5

# === Production (uncomment for deploy) ===
# DOCKER_REGISTRY=ghcr.io
# DOCKER_IMAGE=your-github-username/golden-connect
# VERSION=latest
# APP_ENV=production
# APP_DEBUG=false
# LOG_LEVEL=warning
